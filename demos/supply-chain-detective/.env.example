# OpenAI-compatible model settings for the Eino agent.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
# OPENAI_BY_AZURE=false
# OPENAI_API_VERSION=

# Values below are printed by `task demo:start`.
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=NorthwindRelay
MSSQL_USERNAME=sa
MSSQL_PASSWORD=SupplyChain!2026
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_ACCESS_LEVEL=READONLY

# Optional: override if the demo directory is moved away from the repo root.
MSSQL_MCP_SERVER_DIR=../..

# Optional: accepts Go durations such as 5m or plain seconds.
DEMO_AGENT_TIMEOUT=5m
DEMO_AGENT_MAX_ITERATIONS=24
